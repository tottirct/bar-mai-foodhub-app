generator client {
  provider = "prisma-client-js"
  output   = "./generated/mysql" // ป้องกันการทับซ้อนกับ Client ของ MongoDB
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_DATABASE_URL")
}

model User {
  id     Int    @id @default(autoincrement())
  email  String @unique
  name   String
  wallet Float  @default(0.0)
  role   Role   @default(CUSTOMER)

  // Relations
  orders Order[]
  shops  Shop[]
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

model Shop {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int

  // Relations
  user   User    @relation(fields: [ownerId], references: [id])
  menus  Menu[]
  orders Order[]
}

model Menu {
  id     Int    @id @default(autoincrement())
  name   String
  price  Float
  shopId Int

  // Relations
  shop Shop @relation(fields: [shopId], references: [id])
}

model Order {
  id           Int      @id @default(autoincrement())
  userId       Int
  shopId       Int
  totalPrice   Float
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  mongoOrderId String?

  // Relations
  user User @relation(fields: [userId], references: [id])
  shop Shop @relation(fields: [shopId], references: [id])
}

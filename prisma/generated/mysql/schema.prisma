generator client {
  provider = "prisma-client-js"
  output   = "./generated/mysql" // ป้องกันการทับซ้อนกับ Client ของ MongoDB
}

datasource db {
  provider = "mysql"
  url      = env("MYSQL_DATABASE_URL")
}

model User {
  id       Int     @id @default(autoincrement())
  email    String  @unique
  name     String
  username String  @unique
  password String
  role     Role    @default(CUSTOMER)
  orders   Order[]
  shops    Shop[]
  wallets  Wallet?
}

model Wallet {
  id      Int  @id @default(autoincrement())
  balance Int  @default(0)
  userId  Int  @unique
  user    User @relation(fields: [userId], references: [id])
}

enum Role {
  CUSTOMER
  OWNER
  ADMIN
}

model Shop {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  ownerId     Int
  isOpen      Boolean
  wallet      Int     @default(0)
  user        User    @relation(fields: [ownerId], references: [id])
  menus       Menu[]
  orders      Order[]
}

model Menu {
  id      Int          @id @default(autoincrement())
  name    String
  price   Int
  shopId  Int
  shop    Shop         @relation(fields: [shopId], references: [id])
  options MenuOption[]
}

model MenuOption {
  id     Int    @id @default(autoincrement())
  name   String
  price  Int
  menuId Int

  menu Menu @relation(fields: [menuId], references: [id])
}

model Order {
  id           Int      @id @default(autoincrement())
  userId       Int
  shopId       Int
  totalPrice   Int
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  mongoOrderId String?
  user         User     @relation(fields: [userId], references: [id])
  shop         Shop     @relation(fields: [shopId], references: [id])
}
